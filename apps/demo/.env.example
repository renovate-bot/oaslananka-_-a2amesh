# LLM Provider
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Registry and runtime
REGISTRY_URL=http://localhost:3099
REGISTRY_TOKEN=
RUN_EMBEDDED_REGISTRY=true
ALLOW_PRIVATE_NETWORKS=false

# Agent ports
PORT_RESEARCHER=3001
PORT_WRITER=3002
PORT_ORCHESTRATOR=3003

# Public URLs used for registration
RESEARCHER_URL=http://localhost:3001
WRITER_URL=http://localhost:3002
ORCHESTRATOR_URL=http://localhost:3003

# Optional tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=a2amesh-demo

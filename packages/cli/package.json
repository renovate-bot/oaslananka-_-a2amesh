{
  "name": "@a2amesh/cli",
  "version": "0.4.0-alpha.1",
  "description": "A2A Mesh command-line interface for initialization, validation, conformance, registry operations, and release checks.",
  "keywords": [
    "a2a",
    "a2amesh",
    "a2a-mesh",
    "agent-to-agent",
    "agents",
    "cli",
    "registry",
    "runtime",
    "typescript"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://oaslananka.github.io/a2amesh/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2amesh.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2amesh/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "bin": {
    "a2amesh": "bin/a2amesh.js"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-tsc-package.mjs",
    "start": "node dist/index.js",
    "test": "vitest run --root ../.. --config vitest.config.ts --project unit packages/cli/tests",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@a2amesh/runtime": "workspace:^",
    "@a2amesh/registry": "workspace:^",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "typescript": "6.0.3"
  },
  "type": "module",
  "engines": {
    "node": ">=22.22.1 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json",
    "bin"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}

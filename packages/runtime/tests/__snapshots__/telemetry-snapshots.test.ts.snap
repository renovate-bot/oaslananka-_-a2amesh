exports[`OpenTelemetry telemetry snapshots > snapshots server, client propagation and outbound HTTP spans > otel spans 1`] = `
[
  {
    "attributes": {
      "a2a.agent_name": "Telemetry Snapshot Agent",
      "rpc.method": "message/send",
    },
    "name": "a2a.handleRpc",
    "scope": "@a2amesh/runtime",
    "status": "OK",
  },
  {
    "attributes": {
      "a2a.context_id": "context-telemetry",
      "a2a.task_id": "<task-id>",
    },
    "name": "a2a.processTask",
    "scope": "@a2amesh/runtime",
    "status": "OK",
  },
  {
    "attributes": {
      "a2a.registry.operation": "registration",
      "a2a.transport": "http",
      "http.attempt": 1,
      "http.max_retries": 1,
      "http.method": "POST",
      "http.status_code": 201,
      "http.url": "https://downstream.example/a2a/health",
    },
    "name": "http.request",
    "scope": "@a2amesh/runtime",
    "status": "OK",
  },
]
`;
